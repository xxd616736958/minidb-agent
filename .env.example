# ============================================================
# LLM Provider — choose "deepseek" or "openai"
# ============================================================
LLM_PROVIDER=deepseek

# DeepSeek (used when LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# LLM Configuration
# ============================================================
# deepseek-chat (V3), deepseek-reasoner (R1), gpt-4o, gpt-4-turbo
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096

# ============================================================
# LangSmith Observability (Required for tracing)
# ============================================================
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=zuixiaoagent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ============================================================
# Database — PostgreSQL (Production) or SQLite fallback
# ============================================================
# PostgreSQL mode (uncomment to enable):
# POSTGRES_URI=postgresql://user:password@localhost:5432/agent_memory

# SQLite mode (default, auto-detected when POSTGRES_URI is empty):
# Falls back to ./data/agent_checkpoints.sqlite

# ============================================================
# Agent Configuration
# ============================================================
MAX_RETRIES=3
NODE_TIMEOUT_SECONDS=60
MEMORY_WINDOW_TOKENS=8000
MEMORY_COMPACT_THRESHOLD=12000

# ============================================================
# Shell Tool Configuration
# ============================================================
# Comma-separated allowed commands (default shown):
COMMAND_WHITELIST=ls,cat,grep,find,pwd,echo,python3,python,pip3,pip,node,npm,git,curl,wget,head,tail,wc,sort,mkdir,touch,cp,mv,chmod,chown,ps,kill,docker,kubectl,make,cargo,go,rustc,javac,tsc
# Dangerous commands that always require human approval:
DANGEROUS_COMMANDS=rm,dd,mkfs,shutdown,reboot,sudo,su,chown,chmod

# ============================================================
# Server Authentication
# ============================================================
# Set to enable API key auth on the server (omit for local dev):
# AGENT_API_KEY=your-secret-api-key-here

# ============================================================
# Logging
# ============================================================
AGENT_LOG_LEVEL=INFO
